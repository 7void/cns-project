# Copy to .env (optional) or set in your shell before running demos.

# Authority (client demo default is localhost:8000)
AUTHORITY_BASE_URL=http://127.0.0.1:8000

# MinIO connection used by storage/minio_adapter.py
# If using docker-compose.yml provided in this repo:
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=cns-project
MINIO_SECURE=false
